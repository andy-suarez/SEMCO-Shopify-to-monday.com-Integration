# Monday.com API
MONDAY_API_KEY=your_monday_api_key_here
MONDAY_BOARD_ID=your_board_id_here
MONDAY_SAMPLE_BOARD_ID=your_sample_inventory_board_id_here

# Shopify Webhook Signing Secrets
SHOPIFY_SEMCO_PRO_SECRET=your_semco_pro_webhook_secret
SHOPIFY_SEMCO_SPACES_SECRET=your_semco_spaces_webhook_secret
SHOPIFY_SEMCO_CONNECT_SECRET=your_semco_connect_webhook_secret
SHOPIFY_SEMCO_WORKS_SECRET=your_semco_works_webhook_secret

# Email Notifications (Gmail SMTP)
SMTP_EMAIL=your_gmail_address@gmail.com
SMTP_PASSWORD=your_gmail_app_password
NOTIFY_EMAILS=recipient1@example.com,recipient2@example.com

# ---------------------------------------------------------------------------
# Sample Inventory Sync (Monday → Shopify, one-way, Render Cron-triggered)
# ---------------------------------------------------------------------------
# Shopify SEMCO Pro — OAuth client_credentials (2026 Dev Dashboard app)
SHOPIFY_PRO_STORE_DOMAIN=semcopro.myshopify.com
SHOPIFY_PRO_CLIENT_ID=your_pro_client_id
SHOPIFY_PRO_CLIENT_SECRET=your_pro_client_secret
SHOPIFY_PRO_LOCATION_ID=your_pro_location_id
SHOPIFY_PRO_SAMPLE_PRODUCT_ID=your_pro_sample_product_id

# Shared secret protecting the /sync-inventory endpoint (random 32+ char string)
SYNC_AUTH_TOKEN=generate_a_long_random_string_here

# Spaces sync credentials (add later, same pattern):
# SHOPIFY_SPACES_STORE_DOMAIN=
# SHOPIFY_SPACES_CLIENT_ID=
# SHOPIFY_SPACES_CLIENT_SECRET=
# SHOPIFY_SPACES_LOCATION_ID=
# SHOPIFY_SPACES_SAMPLE_PRODUCT_ID=
